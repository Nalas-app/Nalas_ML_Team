{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Recipe",
  "description": "A structured, validated recipe object",
  "properties": {
    "recipe_id": {
      "type": "string",
      "description": "Unique identifier for the recipe"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "description": "Name of the recipe"
    },
    "ingredients": {
      "type": "array",
      "minItems": 1,
      "description": "List of ingredients with quantity, unit, and item name",
      "items": {
        "type": "object",
        "properties": {
          "quantity": { "type": ["number", "null"] },
          "unit":     { "type": ["string", "null"] },
          "item":     { "type": "string", "minLength": 1 },
          "original_text": { "type": "string" },
          "normalized_item": { "type": ["string", "null"] }
        },
        "required": ["item", "original_text"]
      }
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of cooking steps",
      "items": { "type": "string", "minLength": 5 }
    },
    "prep_time_minutes": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1440,
      "description": "Total preparation time in minutes"
    },
    "servings": {
      "type": ["number", "null"],
      "minimum": 1,
      "maximum": 200,
      "description": "Number of servings the recipe yields"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Auto-generated descriptive tags"
    },
    "_meta": {
      "type": "object",
      "description": "Pipeline processing metadata",
      "properties": {
        "imputed_fields":     { "type": "array", "items": { "type": "string" } },
        "original_values":    { "type": "object" },
        "parse_warnings":     { "type": "array", "items": { "type": "string" } },
        "is_duplicate":       { "type": "boolean" },
        "duplicate_of":       { "type": ["string", "null"] }
      }
    }
  },
  "required": ["recipe_id", "name", "ingredients", "instructions"]
}
